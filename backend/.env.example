# ─── App ──────────────────────────────────────────────────────
SECRET_KEY=change-me-please-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://tarng:tarng_secret@localhost:5432/tarng_db

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── MinIO / S3 ───────────────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=tarng_minio
S3_SECRET_KEY=tarng_minio_secret
S3_BUCKET_NAME=tarng-media
S3_REGION=us-east-1

# ─── CORS ─────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ─── Sentry ───────────────────────────────────────────────────
SENTRY_DSN=

# ─── Email ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@tarng.com
EMAILS_FROM_NAME=tarng

# ─── Environment ──────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
